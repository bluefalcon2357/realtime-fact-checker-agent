# Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project
VERTEX_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true

# Gemini model
GEMINI_MODEL=gemini-flash-latest

# Runtime
LOCAL_MODE=true
STUB_LLM=false
CHUNK_SECONDS=5
DEDUPE_TTL_SECONDS=60
MAX_CLAIMS_PER_SESSION=50

# Firestore
FIRESTORE_COLLECTION=verdicts
# FIRESTORE_EMULATOR_HOST=localhost:8200

# Pub/Sub (only used when LOCAL_MODE=false)
PUBSUB_CHUNK_TOPIC=fact-check-chunks
PUBSUB_VERDICT_TOPIC=fact-check-verdicts

# Trusted source allowlist (comma-separated)
TRUSTED_DOMAINS=reuters.com,apnews.com,bbc.com,npr.org,cdc.gov,nih.gov,who.int,nature.com,science.org

# Server
HOST=0.0.0.0
PORT=8080
